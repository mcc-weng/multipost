# === Multi-Platform Posting Scripts ===
# Copy this file to .env and fill in your tokens.
# Each platform is optional — only fill in what you use.

# --- Threads ---
THREADS_ACCESS_TOKEN=
THREADS_USER_ID=
THREADS_APP_SECRET=

# --- Instagram ---
INSTAGRAM_BUSINESS_ACCOUNT_ID=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_REFRESH_TOKEN=

# --- X (Twitter) ---
# Requires X API Basic tier ($100/month) for write access
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# --- LinkedIn ---
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_ID=

# --- TikTok ---
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_REFRESH_TOKEN=

# --- YouTube ---
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_API_KEY=
